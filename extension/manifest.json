{
  "manifest_version": 3,
  "name": "Reply Coach AI",
  "version": "1.0.1",
  "description": "AI communication coach for better replies.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Reply Coach AI"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://reply-coach-ai-backend.onrender.com/*"
  ]
}